datasource db {
  provider  = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

model Role {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Department {
  id          Int        @id @default(autoincrement())
  code        String?    @unique @default(uuid())
  name        String     @unique
  description String?
  employees   Employee[]
  assets      Asset[]
  users       User[]     @relation("UserDepartments")
  departmentHistory DepartmentHistory[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Employee {
  id           Int        @id @default(autoincrement())
  code         String     @unique
  fullName     String
  email        String     @unique
  phone        String?
  position     String?
  status       String     @default("ACTIVE") // ACTIVE, INACTIVE
  startDate    DateTime?
  endDate      DateTime?
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  userId       Int?       @unique
  user         User?      @relation(fields: [userId], references: [id])
  
  assignedAssets AssetAssignment[]
  tickets        SupportTicket[]
  historyActions AssetHistory[]    @relation("PerformedBy")
  maintenanceCreated MaintenanceRecord[] @relation("MaintenanceCreator")
  liquidationsCreated LiquidationRecord[] @relation("LiquidationCreator")
  timekeepingRecords TimekeepingRecord[]
  departmentHistory   DepartmentHistory[]

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model DepartmentHistory {
  id           Int        @id @default(autoincrement())
  employeeId   Int
  employee     Employee   @relation(fields: [employeeId], references: [id])
  departmentId Int
  department   Department @relation(fields: [departmentId], references: [id])
  startDate    DateTime   @default(now())
  endDate      DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([employeeId, startDate])
}

model User {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String
  roleId    Int
  role      Role      @relation(fields: [roleId], references: [id])
  employee  Employee?

  permissions Json?   // Role-based permissions override
  departments Department[] @relation("UserDepartments")

  activityLogs ActivityLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  resource  String
  details   Json?
  timestamp DateTime @default(now())
}

model BackupConfig {
  id              Int      @id @default(autoincrement())
  storagePath     String
  autoBackup      Boolean  @default(false)
  schedule        String?  // Cron expression
  lastBackupAt    DateTime?
  updatedAt       DateTime @updatedAt
}

model BackupHistory {
  id          Int      @id @default(autoincrement())
  filename    String
  size        BigInt
  status      String   // SUCCESS, FAILED
  error       String?
  timestamp   DateTime @default(now())
}

model Supplier {
  id        Int      @id @default(autoincrement())
  code      String   @unique @default(uuid())
  name      String   @unique
  contact   String?
  email     String?
  phone     String?
  status    String   @default("ACTIVE") // ACTIVE, INACTIVE
  assets    Asset[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EquipmentType {
  id          Int      @id @default(autoincrement())
  code        String   @unique // matb
  name        String   // tentb
  description String?
  assets      Asset[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Asset {
  id            Int      @id @default(autoincrement())
  assetCode     String   @unique
  name          String
  description   String?
  
  // New technical specs
  model           String?
  serialNumber    String?
  manufacturer    String?
  purchaseDate    DateTime?
  requiresCalibration Boolean @default(false)
  calibrationCycle Int? // in days

  // Extended Asset Details
  symbol          String?  // Ký hiệu
  origin          String?  // Nước SX
  manufactureYear String?  // Năm SX
  machineCode     String?  // Mã Máy
  registrationNumber String? // Số lưu hành
  manualLink      String?  // HDSD (Link)

  equipmentTypeId Int
  equipmentType   EquipmentType @relation(fields: [equipmentTypeId], references: [id])
  departmentId  Int?
  department    Department? @relation(fields: [departmentId], references: [id])
  supplierId    Int?
  supplier      Supplier?   @relation(fields: [supplierId], references: [id])
  purchasePrice Float?
  qrCode        String?  @unique
  unit          String?  @default("Cái")
  group         String?  // Thiết bị y tế, Thiết bị CNTT, Thiết bị hành chính
  statusId      Int      @default(0) // 0: Hoạt động, 1: Hỏng, 2: Ngừng hoạt động...
  statusConfig  AssetStatus @relation(fields: [statusId], references: [matt])
  
  lastCalibrationDate DateTime?
  nextCalibrationDate DateTime?
  
  assignments    AssetAssignment[]
  histories      AssetHistory[]
  maintenances   MaintenanceRecord[]
  tickets        SupportTicket[]
  calibrations   CalibrationRecord[]
  liquidation    LiquidationRecord?
  
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AssetStatus {
  matt   Int     @id
  tentt  String
  assets Asset[]
}

model CalibrationRecord {
  id              Int      @id @default(autoincrement())
  assetId         Int
  asset           Asset    @relation(fields: [assetId], references: [id])
  calibrationDate DateTime
  expirationDate  DateTime
  result          String   @default("PASS") // PASS, FAIL
  certificateUrl  String?
  notes           String?
  performedBy     String?   // Agency/Person
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}


model AssetAssignment {
  id           Int      @id @default(autoincrement())
  assetId      Int
  asset        Asset    @relation(fields: [assetId], references: [id])
  employeeId   Int
  employee     Employee @relation(fields: [employeeId], references: [id])
  assignedDate DateTime @default(now())
  returnDate   DateTime?
  status       String   @default("ACTIVE") // ACTIVE, RETURNED
}

model AssetHistory {
  id          Int      @id @default(autoincrement())
  assetId     Int
  asset       Asset    @relation(fields: [assetId], references: [id])
  actionType  String   // ASSIGN, RETURN, MAINTENANCE_START, MAINTENANCE_END, RETIRE, UPDATE
  description String?
  date        DateTime @default(now())
  performedById Int
  performedBy   Employee @relation("PerformedBy", fields: [performedById], references: [id])
}

model MaintenanceRecord {
  id              Int      @id @default(autoincrement())
  code            String?  @unique // Mã phiếu SC-...
  name            String?  // Tên phiếu
  assetId         Int
  asset           Asset    @relation(fields: [assetId], references: [id])
  description     String
  cost            Float?
  startDate       DateTime
  endDate         DateTime?
  status          String   @default("PENDING") // PENDING, IN_PROGRESS, COMPLETED
  contractorName  String?
  
  creatorId       Int?
  creator         Employee? @relation("MaintenanceCreator", fields: [creatorId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TimekeepingSymbol {
  id          Int      @id @default(autoincrement())
  code        String   @unique // Makyhieu
  name        String   // tenkyhieu
  records     TimekeepingRecord[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TimekeepingRecord {
  id              Int      @id @default(autoincrement())
  employeeId      Int
  employee        Employee @relation(fields: [employeeId], references: [id])
  date            DateTime @db.Date
  symbolId        Int
  symbol          TimekeepingSymbol @relation(fields: [symbolId], references: [id])
  overtimeHours   Float?   @default(0)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([employeeId, date])
}

model SupportTicket {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  assetId     Int?
  asset       Asset?   @relation(fields: [assetId], references: [id])
  requesterId Int
  requester   Employee @relation(fields: [requesterId], references: [id])
  status      String   @default("OPEN") // OPEN, IN_PROGRESS, RESOLVED, CLOSED
  priority    String   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LiquidationRecord {
  id              Int      @id @default(autoincrement())
  assetId         Int      @unique
  asset           Asset    @relation(fields: [assetId], references: [id])
  date            DateTime @default(now()) // Ngày đưa vào thanh lý/thu hồi
  reason          String
  status          String   @default("PENDING") // PENDING (Chờ thanh lý), COMPLETED (Đã thanh lý)
  documentUrl     String?  // Link hồ sơ thanh lý
  
  creatorId       Int?
  creator         Employee? @relation("LiquidationCreator", fields: [creatorId], references: [id])

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
